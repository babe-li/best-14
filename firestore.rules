rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth utility check helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. Settings Collection rules
    // Verified users are allowed to read settings and admins/users to write configs
    match /settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
